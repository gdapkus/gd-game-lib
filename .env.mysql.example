# MySQL Database Configuration Example
# Copy this file to .env.local and update with your actual MySQL credentials

# Trello API Configuration
TRELLO_KEY=<your Trello API Key>
TRELLO_BOARD_ID=<Your Trello Board ID>
VITE_TRELLO_KEY=<Your Trello API Key>

# BoardGameGeek API Token (optional, for higher rate limits)
BGG_API_TOKEN=<your BGG API token>

# Express Server Configuration
EXPRESS_PORT=3001

# MySQL Database Configuration - Option 1: Connection String
# Format: mysql://username:password@host:port/database?ssl=true
DATABASE_URL=mysql://your_username:your_password@your_mysql_host:3306/gamesdb

# MySQL Database Configuration - Option 2: Individual Parameters
# (Used if DATABASE_URL is not set)
DBSERVER=your_mysql_host.com
DBPORT=3306
GAMELIBDB=gamesdb
DBUSER_ID=your_mysql_username
DBPASS=your_mysql_password

# Optional: Enable SSL for MySQL connection
DB_SSL=false

# Notes:
# - DATABASE_URL takes precedence over individual parameters
# - Default MySQL port is 3306
# - Set DB_SSL=true if your MySQL host requires SSL
# - For cloud MySQL providers (AWS RDS, Google Cloud SQL, Azure), SSL is typically required
